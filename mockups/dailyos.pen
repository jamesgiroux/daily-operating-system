                  "ref": "j1jVA",
                  "name": "dd1",
                  "x": 0,
                  "y": 54
                },
                {
                  "id": "2VWav",
                  "type": "ref",
                  "ref": "j1jVA",
                  "name": "dd2",
                  "x": 0,
                  "y": 310,
                  "descendants": {
                    "Sdqq1": {
                      "width": "fit_content"
                    },
                    "ks8wa": {
                      "fill": "#c4654a"
                    },
                    "myeQa": {
                      "content": "Globex Corp"
                    },
                    "b47Fi": {
                      "content": "$980K ARR",
                      "x": 133
                    },
                    "Tl2en": {
                      "content": "The relationship stabilized this quarter after a difficult Q4. Support ticket volume is down 30% and the new technical lead has been responsive. The risk is the incoming VP — we need to establish the relationship before the April transition."
                    },
                    "crRPQ": {
                      "content": "Key Risks"
                    },
                    "C8AjE": {
                      "width": "fit_content"
                    },
                    "v0Ipm": {
                      "content": "› VP transition in April — no intro meeting scheduled yet"
                    },
                    "7BX0V": {
                      "content": "› Support contract renewal in July — pricing discussion needed"
                    },
                    "IlAYG": {
                      "content": "RENEWAL"
                    },
                    "TrCrM": {
                      "content": "Jul 2026"
                    }
                  }
                },
                {
                  "id": "aRNMg",
                  "type": "ref",
                  "ref": "j1jVA",
                  "name": "dd3",
                  "x": 0,
                  "y": 566,
                  "descendants": {
                    "Sdqq1": {
                      "width": "fit_content"
                    },
                    "ks8wa": {
                      "fill": "#7eaa7b"
                    },
                    "myeQa": {
                      "content": "Initech"
                    },
                    "b47Fi": {
                      "content": "$580K ARR",
                      "x": 84
                    },
                    "Tl2en": {
                      "content": "The expansion closed 14 months ahead of schedule — a strong signal of product-market fit within their org. Onboarding kicks off next week. The 30/60/90 plan is critical to ensure the expanded footprint delivers value quickly."
                    },
                    "crRPQ": {
                      "content": "Onboarding Milestones"
                    },
                    "C8AjE": {
                      "width": "fit_content"
                    },
                    "v0Ipm": {
                      "content": "› Week 1: Kickoff + provisioning for 3 new teams"
                    },
                    "7BX0V": {
                      "content": "› Day 30: First usage metrics review"
                    },
                    "IlAYG": {
                      "content": "RENEWAL"
                    },
                    "TrCrM": {
                      "content": "Dec 2026"
                    }
                  }
                }
              ]
            },
            {
              "id": "W2jPC",
              "type": "ref",
              "ref": "1bdhM",
              "name": "themeSec",
              "x": 0,
              "y": 1599,
              "descendants": {
                "E34v2": {
                  "content": "Three themes emerge across the portfolio this quarter. First, organic adoption is outpacing sales-led expansion — Meridian and Initech both grew through internal champions rather than top-down mandates. Second, executive engagement correlates directly with health scores — accounts with quarterly exec touchpoints are 3x more likely to expand. Third, the support experience is the leading indicator of renewal risk — Globex's Q4 trouble started with unresolved tickets, not relationship gaps.",
                  "fontStyle": "normal"
                }
              }
            },
