{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dailyos/intelligence-quality-badge",
	"title": "Intelligence Quality Badge",
	"category": "dailyos",
	"description": "DailyOS IntelligenceQualityBadge primitive \u2014 score-derived quality status.",
	"supports": {
		"html": false,
		"reusable": false,
		"inserter": true
	},
	"attributes": {
		"composition_id": {
			"type": "string"
		},
		"composition_version": {
			"type": "integer",
			"default": 0
		},
		"block_id": {
			"type": "string"
		},
		"watermarks": {
			"type": "object",
			"default": {}
		},
		"cache_hint_token": {
			"type": "string",
			"default": ""
		},
		"block_instance_id": {
			"type": "string"
		},
		"qualityScore": {
			"type": "number",
			"default": 0
		},
		"hasNewSignals": {
			"type": "boolean",
			"default": false
		},
		"lastEnriched": {
			"type": "string",
			"default": ""
		},
		"enrichedAt": {
			"type": "string",
			"default": ""
		},
		"showLabel": {
			"type": "boolean",
			"default": false
		},
		"showTooltip": {
			"type": "boolean",
			"default": false
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./edit.js",
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css"
}
