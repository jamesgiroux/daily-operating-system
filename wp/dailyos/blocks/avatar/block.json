{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dailyos/avatar",
	"title": "Avatar",
	"category": "dailyos",
	"description": "DailyOS Avatar primitive \u2014 runtime-resolved person photo with initials fallback.",
	"supports": {
		"html": false,
		"reusable": false,
		"inserter": true
	},
	"attributes": {
		"composition_id": {
			"type": "string"
		},
		"composition_version": {
			"type": "integer",
			"default": 0
		},
		"block_id": {
			"type": "string"
		},
		"watermarks": {
			"type": "object",
			"default": {}
		},
		"cache_hint_token": {
			"type": "string",
			"default": ""
		},
		"block_instance_id": {
			"type": "string"
		},
		"name": {
			"type": "string",
			"default": ""
		},
		"personId": {
			"type": "string",
			"default": ""
		},
		"photoUrl": {
			"type": "string",
			"default": ""
		},
		"size": {
			"type": "number",
			"default": 32
		},
		"className": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./edit.js",
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css"
}
