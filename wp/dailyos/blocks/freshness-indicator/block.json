{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dailyos/freshness-indicator",
	"title": "Freshness Indicator",
	"category": "dailyos",
	"description": "DailyOS FreshnessIndicator primitive \u2014 server-rendered relative recency label.",
	"supports": {
		"html": false,
		"reusable": false,
		"inserter": true
	},
	"attributes": {
		"composition_id": {
			"type": "string"
		},
		"composition_version": {
			"type": "integer",
			"default": 0
		},
		"block_id": {
			"type": "string"
		},
		"watermarks": {
			"type": "object",
			"default": {}
		},
		"cache_hint_token": {
			"type": "string",
			"default": ""
		},
		"block_instance_id": {
			"type": "string"
		},
		"at": {
			"type": "string",
			"default": ""
		},
		"enrichedAt": {
			"type": "string",
			"default": ""
		},
		"format": {
			"type": "string",
			"default": "relative",
			"enum": [
				"relative",
				"absolute",
				"both"
			]
		},
		"dateFormat": {
			"type": "string",
			"default": "relative",
			"enum": [
				"relative",
				"short"
			]
		},
		"stalenessThreshold": {
			"type": "number",
			"default": 48
		},
		"verb": {
			"type": "string",
			"default": "Updated"
		},
		"fragments": {
			"type": "array",
			"default": []
		},
		"variant": {
			"type": "string",
			"default": "inline",
			"enum": [
				"inline",
				"strip"
			]
		},
		"className": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./edit.js",
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css"
}
