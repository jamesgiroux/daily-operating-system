{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dailyos/pill",
	"title": "Pill",
	"category": "dailyos",
	"description": "DailyOS Pill primitive — inline status / label / category badge.",
	"supports": {
		"html": false,
		"reusable": false,
		"inserter": true
	},
	"attributes": {
		"composition_id": {
			"type": "string"
		},
		"composition_version": {
			"type": "integer",
			"default": 0
		},
		"block_id": {
			"type": "string"
		},
		"watermarks": {
			"type": "object",
			"default": {}
		},
		"cache_hint_token": {
			"type": "string",
			"default": ""
		},
		"block_instance_id": {
			"type": "string"
		},
		"label": {
			"type": "string",
			"default": ""
		},
		"tone": {
			"type": "string",
			"default": "neutral",
			"enum": [
				"sage",
				"turmeric",
				"terracotta",
				"larkspur",
				"olive",
				"eucalyptus",
				"neutral"
			]
		},
		"size": {
			"type": "string",
			"default": "standard",
			"enum": [
				"standard",
				"compact"
			]
		},
		"dot": {
			"type": "boolean",
			"default": false
		},
		"interactive": {
			"type": "boolean",
			"default": false
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./edit.js",
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css"
}
