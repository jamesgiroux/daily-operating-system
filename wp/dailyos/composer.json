{
  "name": "dailyos/dailyos-wordpress",
  "description": "DailyOS SurfaceClient plugin for WordPress.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "repositories": [
    {
      "type": "composer",
      "url": "https://wp-packages.org"
    }
  ],
  "require": {
    "php": ">=8.1",
    "wordpress/mcp-adapter": "^0.5.0"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpstan/phpstan": "^1.11",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "lint": "phpcs",
    "stan": "phpstan analyze --no-progress",
    "test": "phpunit --no-coverage",
    "grep-gates": "bash scripts/run-grep-gates.sh"
  },
  "autoload": {
    "psr-4": {
      "DailyOS\\": "includes/"
    },
    "classmap": [
      "includes/"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
