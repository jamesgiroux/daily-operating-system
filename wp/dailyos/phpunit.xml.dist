<?xml version="1.0"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
    bootstrap="tests/bootstrap.php"
    colors="true"
    failOnWarning="true"
    failOnRisky="true"
    cacheDirectory=".phpunit.cache">
    <testsuites>
        <testsuite name="DailyOS">
            <directory>tests/</directory>
            <exclude>tests/bootstrap.php</exclude>
            <!-- StarterKitIntegrationTest.php is a CLI helper script (not a PHPUnit
                 class) that the W1 kit invokes from outside PHPUnit. failOnWarning
                 + class-name mismatch surfaces this on every run. -->
            <exclude>tests/blocks/StarterKitIntegrationTest.php</exclude>
        </testsuite>
    </testsuites>
</phpunit>
